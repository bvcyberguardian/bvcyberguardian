# Copy this file to .env.local for local development
# In Netlify: add these under Site Settings > Environment Variables

# Google Places API (for live Google Reviews — optional, site uses placeholder reviews without it)
GOOGLE_PLACES_API_KEY=
GOOGLE_PLACE_ID=

# SMTP settings for newsletter signup and contact form email delivery
# Use your hosting provider's SMTP credentials (GoDaddy, cPanel, etc.)
SMTP_HOST=mail.bvcyberguardian.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=info@bvcyberguardian.com
SMTP_PASS=
