# Copy this file to .env.local for local development
# In Netlify: add these under Site Settings > Environment Variables

# Google Places API (for live Google Reviews — optional, site uses placeholder reviews without it)
GOOGLE_PLACES_API_KEY=
GOOGLE_PLACE_ID=

# Email delivery for contact form and newsletter (choose one provider)
RESEND_API_KEY=

# Newsletter provider (optional)
MAILCHIMP_API_KEY=
MAILCHIMP_LIST_ID=
